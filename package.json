{
  "name": "leenk",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "check": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "dev": "astro dev",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware --deny-warnings .",
    "lint:fix": "oxlint --type-aware --fix .",
    "prepare": "husky",
    "preview": "wrangler dev",
    "quality": "nub run lint:fix && nub run format",
    "test": "vitest run",
    "test:watch": "vitest",
    "types:check": "wrangler types worker-configuration.d.ts --include-runtime false --check",
    "verify": "nub run lint && nub run format:check && nub run check && nub run test && nub run types:check && nub run build"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@nanostores/persistent": "^1.3.4",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "7.0.7",
    "astro-font": "^1.1.0",
    "astro-simpleanalytics-plugin": "^0.4.0",
    "clsx": "^2.1.1",
    "motion": "^12.42.2",
    "nanostores": "^1.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@astrojs/cloudflare": "14.1.2",
    "@cloudflare/workers-types": "5.20260713.1",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.12.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "^4.110.0"
  },
  "engines": {
    "node": ">=26.5.0"
  },
  "allowBuilds": {
    "esbuild": true,
    "sharp": true,
    "workerd": true
  },
  "packageExtensions": {
    "@astrojs/cloudflare@14.1.2": {
      "dependencies": {
        "prismjs": "1.30.0"
      }
    }
  }
}
