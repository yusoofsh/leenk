    "astro": "7.0.7",
    "astro-font": "^1.1.0",
    "astro-simpleanalytics-plugin": "^0.4.0",
    "clsx": "^2.1.1",
    "motion": "^12.42.2",
    "nanostores": "^1.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
