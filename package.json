    "lint-staged": "^16.4.0",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-packagejson": "^2.5.22",
    "prettier-plugin-tailwindcss": "^0.7.4",
