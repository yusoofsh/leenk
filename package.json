{
  "name": "leenk",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "check": "astro check",
    "deploy": "wrangler deploy",
    "dev": "astro dev",
    "format": "prettier --write .",
