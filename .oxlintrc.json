{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "import",
    "jsx-a11y",
    "react",
    "typescript",
    "unicorn",
    "vitest",
    "oxc"
  ],
  "categories": {
    "correctness": "error",
    "perf": "error",
    "suspicious": "error"
  },
  "ignorePatterns": ["**/*.astro"],
  "rules": {
    "react/react-in-jsx-scope": "off"
  },
  "overrides": [
    {
      "files": ["*.d.ts"],
      "rules": {
        "import/no-unassigned-import": "off"
      }
    }
  ],
  "env": {
    "browser": true,
    "builtin": true,
    "node": true
  }
}
