---
import { AstroFont } from "astro-font";
import { SimpleAnalytics } from "astro-simpleanalytics-plugin";
import { Background } from "../components/background";

import "../styles/global.css";

interface Props {
  canonical?: false | string;
  description?: string;
  robots?: string;
  title?: string;
}

const defaultDescription =
  "Malang-based full-stack/DevOps engineer. Accelerated time-to-production at Nadi; built YDSF’s Muslim crowdfunding platform end-to-end. TypeScript/React, Hono/Bun, Docker/Traefik/Tailscale, OpenTelemetry/Sentry, UU PDP-aware.";
const defaultTitle = "Yusoof Moh — Full-Stack/DevOps Engineer in Indonesia";
const {
  canonical = "https://www.yusoofsh.id/",
  description = defaultDescription,
  robots = "index,follow",
  title = defaultTitle,
} = Astro.props;
---

<!doctype html>
<html lang="en" data-bio-mode="full" data-theme-mode="light">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width" name="viewport" />
    <link href="/favicon.ico" rel="icon" type="image/x-icon" />
    <link rel="manifest" href="/manifest.json" />
    <link
      rel="preload"
      href="/fonts/PlusJakartaSans-VariableFont_wght.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <meta
      content="#f9fafb"
      media="(prefers-color-scheme: light)"
      name="theme-color"
    />
    <meta
      content="#030712"
      media="(prefers-color-scheme: dark)"
      name="theme-color"
    />
    <meta content={Astro.generator} name="generator" />
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta name="author" content="Yusoof Moh" />
    <meta name="robots" content={robots} />
    <meta
      name="keywords"
      content="Yusoof Moh, full-stack engineer Indonesia, DevOps Indonesia, TypeScript React, Hono Bun, Docker Traefik Tailscale, OpenTelemetry Sentry, UU PDP compliance, Nadi, YDSF, crowdfunding platform"
    />
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="id_ID" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script is:inline>
      (() => {
        if (typeof document === "undefined") {
          return;
        }

        const BIO_STORAGE_KEY = "bioMode";
        const THEME_STORAGE_KEY = "themeMode";
        const root = document.documentElement;

        const readStoredValue = (key, allowedValues) => {
          try {
            const stored = window.localStorage.getItem(key);
            if (allowedValues.includes(stored)) {
              return stored;
            }
          } catch {
            return null;
          }
        };

        const systemTheme = () =>
          window.matchMedia &&
          window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";

        const bioMode =
          readStoredValue(BIO_STORAGE_KEY, ["full", "tldr"]) ?? "full";
        const themeMode =
          readStoredValue(THEME_STORAGE_KEY, ["dark", "light"]) ??
          systemTheme();

        root.dataset.bioMode = bioMode;
        root.dataset.themeMode = themeMode;
        root.classList.toggle("dark", themeMode === "dark");
      })();
    </script>
    <title>{title}</title>
    <AstroFont
      config={[
        {
          display: "optional",
          fallback: "sans-serif",
          name: "Plus Jakarta Sans",
          selector: "body",
          src: [
            {
              path: "/fonts/PlusJakartaSans-VariableFont_wght.woff2",
              style: "normal",
            },
          ],
        },
      ]}
    />
    <script>
      type AnalyticsEvent = ((...args: unknown[]) => void) & {
        q?: unknown[][];
      };

      declare global {
        interface Window {
          sa_event?: AnalyticsEvent;
        }
      }

      const saEvent: AnalyticsEvent = (...args) => {
        saEvent.q ? saEvent.q.push(args) : (saEvent.q = [args]);
      };

      window.sa_event ??= saEvent;
    </script>
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Yusoof Moh",
        "alternateName": "Yusoof",
        "jobTitle": "Full-Stack/DevOps Engineer",
        "url": "https://www.yusoofsh.id/",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Malang",
          "addressRegion": "East Java",
          "addressCountry": "ID"
        },
        "knowsAbout": [
          "TypeScript",
          "React",
          "TanStack Start",
          "Hono",
          "Node.js",
          "Bun",
          "Docker",
          "Traefik",
          "Tailscale",
          "GitHub Actions",
          "React Native",
          "Capacitor",
          "OpenTelemetry",
          "Sentry",
          "SigNoz",
          "CI/CD",
          "On-call",
          "Incident Response",
          "UU PDP Compliance"
        ],
        "sameAs": [
          "https://linkedin.com/in/yusoofsh",
          "https://github.com/yusoofsh"
        ],
        "worksFor": {
          "@type": "Organization",
          "name": "Yusoofs Company"
        }
      }
    </script>
  </head>
  <body>
    <a
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:rounded-md focus:bg-white focus:px-4 focus:py-2 focus:text-slate-950 focus:shadow-lg"
      href="#main-content">Skip to content</a
    >
    <main id="main-content">
      <Background client:load>
        <slot />
      </Background>
    </main>
    <SimpleAnalytics allEnvironments={true} collectDNT={true} />
  </body>
</html>
